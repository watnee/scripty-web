{
  "name": "scripty",
  "private": true,
  "description": "Scripty — Railway IaC + Cloudflare Containers deploy support for the Spring Boot app.",
  "scripts": {
    "cf:deploy": "wrangler deploy --config cloudflare/wrangler.jsonc",
    "cf:dev": "wrangler dev --config cloudflare/wrangler.jsonc",
    "cf:sync": "./scripts/sync-railway-cloudflare.sh sync",
    "cf:sync:status": "./scripts/sync-railway-cloudflare.sh status",
    "cf:sync:check": "./scripts/sync-railway-cloudflare.sh check"
  },
  "dependencies": {
    "railway": "^3.5.5"
  },
  "devDependencies": {
    "@cloudflare/containers": "^0.3.7",
    "@cloudflare/workers-types": "^5.20260708.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.110.0"
  }
}
