{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "watchPatterns": [
      "src/**",
      "pom.xml",
      "railway.json",
      "railpack.json"
    ]
  },
  "deploy": {
    "startCommand": "java $JAVA_OPTS -jar target/scripty.jar --server.port=${PORT:-8080} --spring.profiles.active=prod",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
