{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "src/**",
      "pom.xml",
      "Dockerfile",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "sh -c 'java $JAVA_OPTS -jar scripty.jar --server.port=${PORT:-8080} --spring.profiles.active=prod'",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
